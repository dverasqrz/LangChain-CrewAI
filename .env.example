# ================================================================================
# ARQUIVO DE CONFIGURAÇÃO DE EXEMPLO
# ================================================================================
# Copie este arquivo para .env e preencha com suas chaves de API reais
# NUNCA faça commit do arquivo .env com dados sensíveis no repositório!
# ================================================================================

# ================================================================================
# PROVEDORES DE IA PARA EMBEDDINGS E LLM
# ================================================================================

# OpenAI - Obtenha em https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini - Obtenha em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq - Obtenha em https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com

# Anthropic Claude - Obtenha em https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk_ant_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (Local ou Remoto) - API REST em /api/tags
# Formato: http://host:11434 (11434 é a porta padrão do Ollama)
# Exemplos:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
# Desabilitar tentativas de conexão ao Ollama (útil quando servidor está offline)
# OLLAMA_SKIP_CONNECTION=false
# Pular geração de embeddings Ollama (usa OpenAI como fallback para melhor performance)
# SKIP_OLLAMA_EMBEDDINGS=false
# Tamanho do batch para embeddings Ollama (menor = menos sobrecarga de CPU)
# OLLAMA_EMBEDDING_BATCH_SIZE=5

# ================================================================================
# CONFIGURAÇÕES DE MODELOS LLM
# ================================================================================
GROQ_MODEL=llama3-70b-8192
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-sonnet-20240229
DEFAULT_LLM_PROVIDER=groq

# ================================================================================
# CONFIGURAÇÕES DO SISTEMA
# ================================================================================
ENVIRONMENT=development
LOG_LEVEL=info
LLM_TEMPERATURE=0.3
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_CHARS=16000

# ================================================================================
# CONFIGURAÇÕES RAG (Retrieval-Augmented Generation)
# ================================================================================
EMBEDDING_MODEL=text-embedding-3-large
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K_RETRIEVAL=5
RAG_SIMILARITY_THRESHOLD=0.7

# ================================================================================
# CONFIGURAÇÕES DE CACHE
# ================================================================================
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# ================================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# ================================================================================
SECURITY_ENABLE_RATE_LIMITING=true
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW=3600
SECURITY_MAX_FILE_SIZE_MB=50

# ================================================================================
# CONFIGURAÇÕES DE PERSISTÊNCIA
# ================================================================================
PERSISTENCE_ENABLED=false
PERSISTENCE_VECTOR_STORE_PATH=./data/vector_store
PERSISTENCE_LOGS_PATH=./logs
PERSISTENCE_METRICS_PATH=./data/metrics

# ================================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ================================================================================
APP_ENABLE_DEBUG=false
APP_ENABLE_METRICS=true
APP_ENABLE_HEALTH_CHECK=true
APP_HEALTH_CHECK_INTERVAL=60
APP_METRICS_RETENTION_DAYS=30

# ================================================================================
# CONFIGURAÇÕES PINECONE (OPCIONAL)
# ================================================================================
# Obtenha em https://www.pinecone.io/
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=suporte-rag
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_POD_TYPE=p1.x1

# ================================================================================
# CONFIGURAÇÕES DE MONITORAMENTO (OPCIONAL)
# ================================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langchain-project

# ================================================================================
# PROMPT PERSONALIZADO
# ================================================================================
DEFAULT_SYSTEM_PROMPT=Você é um assistente de suporte ao atendimento especializado e profissional. Use as informações fornecidas no contexto para responder às perguntas dos clientes. Seja claro, empático e forneça soluções precisas.