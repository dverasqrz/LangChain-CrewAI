# =========================================================
# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env e preencha com suas chaves
# =========================================================

# =========================================================
# Configurações Globais da Aplicação
# =========================================================
# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Habilitar modo debug (mostra informações adicionais)
ENABLE_DEBUG=false

# =========================================================
# Groq API (para projeto de Marketing)
# =========================================================
# Obtenha sua chave em: https://console.groq.com/
GROQ_API_KEY=

# Modelo Groq padrão
GROQ_MODEL=llama-3.1-8b-instant

# =========================================================
# OpenAI API (para Marketing e Suporte)
# =========================================================
# Obtenha sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo OpenAI padrão
OPENAI_MODEL=gpt-4o-mini

# =========================================================
# Configurações de LLM (globais)
# =========================================================
# Temperatura para geração de texto (0.0 a 1.0)
LLM_TEMPERATURE=0.7

# Timeout em segundos
LLM_TIMEOUT_SECONDS=60

# Número máximo de tentativas
LLM_MAX_RETRIES=2

# =========================================================
# Configurações do Projeto de Suporte e Atendimento (RAG)
# =========================================================
# Modelo de embeddings para RAG
EMBEDDINGS_MODEL=text-embedding-3-small

# Tamanho dos chunks para processamento de documentos
CHUNK_SIZE=1000

# Overlap entre chunks
CHUNK_OVERLAP=200

# Threshold de similaridade para busca
SIMILARITY_THRESHOLD=0.7

# Diretório para armazenar índices FAISS
FAISS_INDEX_PATH=./suporte_atendimento/data/faiss_index

# =========================================================
# Configurações de Cache e Performance
# =========================================================
# Habilitar cache de respostas
ENABLE_CACHE=true

# TTL do cache em segundos
CACHE_TTL=3600

# =========================================================
# Configurações de Segurança
# =========================================================
# Rate limiting (requisições por minuto)
RATE_LIMIT_PER_MINUTE=60

# Habilitar validação de inputs
ENABLE_INPUT_VALIDATION=true

# =========================================================
# Configurações de Monitoramento
# =========================================================
# Habilitar métricas detalhadas
ENABLE_METRICS=true

# URL do LangSmith para monitoramento (opcional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=seu_langsmith_api_key_aqui
LANGCHAIN_PROJECT=langchain-crewai-projetos